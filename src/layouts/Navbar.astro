---
import { Image } from "astro:assets";
import myLogo from "@/assets/logo.svg";

const navData = [
  {
    title: "Themen",
    href: "/themen"
  },
  {
    title: "Home",
    href: "/"
  },
  {
    title: "Aktuelles",
    href: "/termine"
  }
];
---

<nav class="bg-surface shadow-lg sticky top-0 right-0 left-0">
  <ul class="flex justify-center items-center font-bold text-lg">
    {
      navData.map(i => {
        const hasIcon = i.href === "/";
        return (
          <li>
            <a href={i.href} class="p-5">
              {
                hasIcon ? (
                  <Image src={myLogo} alt="Logo" class="size-icon-lg w-auto" />
                ) : i.title
              }
            </a>
          </li>
        )
      })
    }
  </ul>
</nav>