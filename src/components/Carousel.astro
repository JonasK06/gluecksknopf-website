---
// src/components/Carousel.astro
import { Image } from 'astro:assets';

interface Props {
  images: any[];
  class?: string;
}

const { images, class: className = '' } = Astro.props;

// Array verdoppeln für den nahtlosen Endlos-Loop
const duplicatedImages = [...images, ...images];
---

<div class={`carousel-root relative w-full max-w-[95vw] mx-auto overflow-hidden group ${className}`}>
  <button
    aria-label="Vorheriges Bild"
    class="prev-btn absolute left-7 top-1/2 -translate-y-1/2 z-20 origin-center bg-transparent text-white transition-all duration-300 opacity-0 group-hover:opacity-100 cursor-pointer p-2 flex items-center justify-center select-none scale-y-[4] scale-x-[2] hover:scale-y-[4.5] hover:scale-x-[2.5] active:scale-x-300"
  >
    <span class="text-4xl font-bold inline-flex items-center justify-center select-none leading-none -translate-y-[4px]">
      &lsaquo;
    </span>
  </button>

  <button
    aria-label="Nächstes Bild"
    class="next-btn absolute right-7 top-1/2 -translate-y-1/2 z-20 origin-center bg-transparent text-white transition-all duration-300 opacity-0 group-hover:opacity-100 cursor-pointer p-2 flex items-center justify-center select-none scale-y-[4] scale-x-[2] hover:scale-y-[4.5] hover:scale-x-[2.5] active:scale-x-300"
  >
    <span class="text-4xl font-bold inline-flex items-center justify-center select-none leading-none -translate-y-[4px]">
      &rsaquo;
    </span>
  </button>

  <div class="track flex gap-6 overflow-x-auto scroll-smooth snap-x snap-mandatory no-scrollbar">
    {duplicatedImages.map((item) => (
      <div class="snap-start shrink-0 w-[calc((100%-2*1rem)/3)] overflow-hidden hover:opacity-80">
        <Image
          src={item.data ? item.data.coverImage : item}
          alt={item.data ? item.data.title : "Galeriebild"}
          class="w-full h-full object-cover select-none cursor-pointer"
          width={1280}
          height={720}
        />
      </div>
    ))}
  </div>
</div>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<script>
  document.querySelectorAll('.carousel-root').forEach((carousel) => {
    const track = carousel.querySelector('.track') as HTMLElement;
    const prevBtn = carousel.querySelector('.prev-btn');
    const nextBtn = carousel.querySelector('.next-btn');

    if (!track) return;

    let autoScrollInterval: ReturnType<typeof setInterval>;

    // Berechnet die Scrollweite exakt für ein Bild inklusive Lücke (gap)
    const getScrollAmount = () => {
      const item = track.querySelector('div') as HTMLElement;
      if (!item) return track.clientWidth / 3;
      return item.offsetWidth + 24; // 16px ist der gap-4 Abstand
    };

    // Scroll nach rechts mit unsichtbarem Loop
    const scrollNext = () => {
      const amount = getScrollAmount();
      const halfWidth = track.scrollWidth / 2;

      // Wenn die erste Hälfte überschritten ist, geräuschlos zurücksetzen
      if (track.scrollLeft >= halfWidth - 10) {
        track.style.scrollBehavior = 'auto';
        track.scrollLeft -= halfWidth;
        track.offsetHeight; // Reflow erzwingen
        track.style.scrollBehavior = 'smooth';
      }

      track.scrollBy({ left: amount, behavior: 'smooth' });
    };

    // Scroll nach links mit unsichtbarem Loop
    const scrollPrev = () => {
      const amount = getScrollAmount();
      const halfWidth = track.scrollWidth / 2;

      // Wenn ganz links angekommen, zur zweiten Hälfte springen
      if (track.scrollLeft <= 10) {
        track.style.scrollBehavior = 'auto';
        track.scrollLeft += halfWidth;
        track.offsetHeight; // Reflow erzwingen
        track.style.scrollBehavior = 'smooth';
      }

      track.scrollBy({ left: -amount, behavior: 'smooth' });
    };

    const startAutoScroll = () => {
      stopAutoScroll();
      autoScrollInterval = setInterval(scrollNext, 3000);
    };

    const stopAutoScroll = () => clearInterval(autoScrollInterval);

    const pauseAndResume = () => {
      stopAutoScroll();
      setTimeout(startAutoScroll, 5000);
    };

    nextBtn?.addEventListener('click', () => {
      scrollNext();
      pauseAndResume();
    });

    prevBtn?.addEventListener('click', () => {
      scrollPrev();
      pauseAndResume();
    });

    carousel.addEventListener('mouseenter', stopAutoScroll);
    carousel.addEventListener('mouseleave', startAutoScroll);

    startAutoScroll();
  });
</script>